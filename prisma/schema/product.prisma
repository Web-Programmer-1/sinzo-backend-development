enum ProductBadge {
  SALE
  BEST_SELLER
  LOW_STOCK
  OUT_OF_STOCK
  NEW
}

enum ProductColor {
  BLACK
  WHITE
  BLUE
  RED
  GREEN
  YELLOW
  GRAY
  BROWN
  NAVY
  PINK
  PURPLE
  ORANGE
}

model Category {
  id             String @id @default(uuid())
  title          String
  thumbnailImage String

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("categories")
}

model Product {
  id               String        @id @default(uuid())
  title            String
  cardShortTitle String?
  slug             String?       @unique
  description      String?
  productCardImage String?
  price            Float
  stock            Int           @default(0)
  badge            ProductBadge?

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  galleryImages String[] // multiple gallery image

  // color system
   colorVariants Json?

  // size system
  sizes    String[] // ["S", "M", "L", "XL"]
  sizeType String? // MEN / WOMEN / UNISEX

  // size guide modal
  sizeGuideImage String?
  sizeGuideData  Json? // [{size:"M", fullLength:"28", chest:"40", sleeve:"24"}]

  // review summary
  averageRating Float @default(0)
  totalReviews  Int   @default(0)

  cart    Cart[]
  wishlist  Wishlist[]
  reviews Review[]

  orderItem OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("products")
}




model Cart {
  id        String @id @default(uuid())
  guestId   String
  productId String

  quantity      Int     @default(1)
  selectedColor String?
  selectedSize  String?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([guestId])
  @@map("carts")
}





model Wishlist {
  id        String @id @default(uuid())
  guestId   String
  productId String

  selectedColor String?
  selectedSize  String?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([guestId])
  @@unique([guestId, productId, selectedColor, selectedSize])
  @@map("wishlists")
}