enum ProductBadge {
  SALE
  BEST_SELLER
  LOW_STOCK
  OUT_OF_STOCK
  NEW
}

model Category {
  id             String @id @default(uuid())
  title          String
  thumbnailImage String

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("categories")
}

model Product {
  id               String        @id @default(uuid())
  title            String
  slug             String?       @unique
  description      String?
  productCardImage String?
  price            Float
  stock            Int           @default(0)
  badge            ProductBadge?

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  galleryImages String[] // multiple gallery image

  // color system
  colors String[] // ["Black", "Blue", "White"]

  // size system
  sizes    String[] // ["S", "M", "L", "XL"]
  sizeType String? // MEN / WOMEN / UNISEX

  // size guide modal
  sizeGuideImage String?
  sizeGuideData  Json? // [{size:"M", fullLength:"28", chest:"40", sleeve:"24"}]

  // review summary
  averageRating Float @default(0)
  totalReviews  Int   @default(0)

  cart    Cart[]
  reviews Review[]

  orderItem OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("products")
}

model Cart {
  id        String @id @default(uuid())
  userId    String
  productId String

  quantity      Int     @default(1)
  selectedColor String?
  selectedSize  String?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("carts")
}
